    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "A = IN[0]  # list of strings to search IN\r\nB = IN[1]  # list of keywords to search FOR\r\n\r\nS = []\r\n\r\nfor a in A:\r\n    found = False\r\n    for b in B:\r\n        if b in a:\r\n            found = True\r\n            break\r\n    S.append(found)\r\n\r\nOUT = S\r\n",
      "Engine": "CPython3",
